<a class="text-[#A8763E] border-b border-[#A8763E] pb-1 font-['Newsreader'] uppercase tracking-[0.2em] text-[11px] hover:text-[#A8763E] transition-colors duration-300" href="#">Home</a>
<a class="text-[#2D2926] font-['Newsreader'] uppercase tracking-[0.2em] text-[11px] hover:text-[#A8763E] transition-colors duration-300" href="#">Shop</a>
<a class="text-[#2D2926] font-['Newsreader'] uppercase tracking-[0.2em] text-[11px] hover:text-[#A8763E] transition-colors duration-300" href="#">Story</a>
<a class="text-[#2D2926] font-['Newsreader'] uppercase tracking-[0.2em] text-[11px] hover:text-[#A8763E] transition-colors duration-300" href="#">Stockists</a>
