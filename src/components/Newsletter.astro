---
---

<section class="w-full px-8 md:px-16 py-32 bg-linen">
  <div class="max-w-3xl mx-auto flex flex-col gap-y-8 items-center text-center">
    <span class="font-label text-label-caps uppercase tracking-widest text-copper">JOIN THE TABLE</span>
    <h2 class="font-headline text-display-lg italic text-espresso leading-tight">
      Recipes, dispatches,
      <br />
      the occasional cracker drop.
    </h2>
    <p class="font-body text-body-md text-cocoa max-w-md">
      A quiet letter, every other week. Pairings, kitchen notes, and early access to new flavors.
    </p>
    <form class="w-full max-w-xl flex flex-col sm:flex-row gap-3 mt-4">
      <input
        type="email"
        required
        placeholder="your@email.com"
        class="flex-1 px-4 py-4 bg-cream border border-espresso/20 text-espresso placeholder:text-cocoa/50 focus:outline-none focus:border-copper transition-colors font-body"
      />
      <button
        type="submit"
        class="px-8 py-4 bg-espresso text-cream font-label text-label-caps uppercase tracking-widest hover:bg-copper transition-colors"
      >
        Subscribe
      </button>
    </form>
    <p class="font-body text-sm text-cocoa/70 italic">
      No spam. Unsubscribe with one click.
    </p>
  </div>
</section>
