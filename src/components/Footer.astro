---
const year = new Date().getFullYear();
---

<footer class="w-full bg-cream border-t border-espresso/15 py-20 px-8 md:px-12">
  <div class="max-w-container-max mx-auto grid grid-cols-1 md:grid-cols-3 gap-12">
    <div class="flex flex-col gap-y-4">
      <div class="border border-espresso px-4 py-3 inline-block w-fit font-headline text-sm tracking-widest">
        SPROD-KRAAKS
      </div>
      <p class="font-headline italic text-headline-md text-espresso">The craft of the cracker.</p>
      <p class="font-body text-body-md text-cocoa max-w-xs">Crafted with care. Small batches. Natural ingredients. Big flavor.</p>
      <div class="flex gap-x-4 mt-4">
        <a href="#" aria-label="Instagram" class="text-copper hover:text-espresso transition-colors">
          <span class="material-symbols-outlined">photo_camera</span>
        </a>
        <a href="#" aria-label="Facebook" class="text-copper hover:text-espresso transition-colors">
          <span class="material-symbols-outlined">share</span>
        </a>
      </div>
    </div>

    <div class="flex flex-col gap-y-3 font-body text-body-md text-cocoa">
      <a href="/shop"      class="hover:text-copper transition-colors">Shop</a>
      <a href="/story"     class="hover:text-copper transition-colors">Story</a>
      <a href="/stockists" class="hover:text-copper transition-colors">Stockists</a>
      <a href="/journal"   class="hover:text-copper transition-colors">Journal</a>
      <a href="/contact"   class="hover:text-copper transition-colors">Contact</a>
    </div>

    <div class="flex flex-col gap-y-4">
      <h4 class="font-headline text-headline-md text-espresso">Direct Contact</h4>
      <div class="flex flex-col gap-y-1 font-body text-body-md text-cocoa">
        <p class="font-medium text-espresso">Marwan Cabbabé</p>
        <p>+961 3 827 681 · Lebanon</p>
        <p>m.cabbabe@sprod-kraaks.com</p>
      </div>
      <div class="flex flex-col gap-y-1 font-body text-body-md text-cocoa pt-2">
        <p class="font-medium text-espresso">David Asseily Capretti</p>
        <p>+971 556 55 7923 · UAE</p>
        <p>d.capretti@sprod-kraaks.com</p>
      </div>
    </div>
  </div>

  <div class="max-w-container-max mx-auto mt-16 pt-8 border-t border-espresso/10 flex flex-col md:flex-row justify-between gap-4 font-body text-sm text-cocoa">
    <p>© {year} Sprød-Kråaks. Founders Marwan & David. All rights reserved.</p>
    <div class="flex gap-x-8">
      <a href="#" class="hover:text-copper transition-colors">Privacy Policy</a>
      <a href="#" class="hover:text-copper transition-colors">Terms</a>
    </div>
  </div>
</footer>
