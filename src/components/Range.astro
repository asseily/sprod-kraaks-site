---
const products = [
  { slug: 'cheesy',   name: 'Grate to be Cheesy',  flavor: 'Nutty, melted, addictive.',           tag: 'ORIGINAL' },
  { slug: 'falafel',  name: 'I feel for Falafel',   flavor: 'Spiced, herbal, deep.',               tag: 'ORIGINAL' },
  { slug: 'olive',    name: 'I olive you',          flavor: 'Earthy, mediterranean, briny.',       tag: 'ORIGINAL' },
  { slug: 'sesame',   name: "Sesame's treat",       flavor: 'Toasted, sweet, snappy.',             tag: 'ORIGINAL' },
  { slug: 'tomato',   name: "That's a spicy tomato",flavor: 'Sun-ripe, smoky, slow.',              tag: 'ORIGINAL' },
  { slug: 'thyme',    name: 'Thymes are good',      flavor: 'Wild, bright, lebanese.',             tag: 'ORIGINAL' },
];
---

<section class="w-full px-8 md:px-16 py-32 flex flex-col gap-y-24 bg-cream">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-x-16 gap-y-8 items-end">
    <h2 class="md:col-span-7 font-headline text-display-lg italic text-espresso leading-none">
      A range to graze.
    </h2>
    <p class="md:col-span-5 font-body text-body-lg text-cocoa max-w-md">
      Twelve crackers across two ranges. Original is for everyday joy. Protein+ is for the days you need a little more.
    </p>
  </div>

  <div class="border-t border-espresso/15"></div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-24">
    {products.map((p) => (
      <a href={`/shop#${p.slug}`} class="group flex flex-col gap-y-6">
        <div class="aspect-square w-full bg-linen overflow-hidden relative flex items-center justify-center p-6">
          <img
            src={`/products/${p.slug}.png`}
            alt={p.name}
            class="max-w-full max-h-full object-contain transition-transform duration-700 group-hover:scale-[1.02]"
            loading="lazy"
          />
        </div>
        <div class="flex flex-col gap-y-3 px-1">
          <span class="font-label text-label-caps uppercase tracking-widest text-copper">{p.tag}</span>
          <h3 class="font-headline text-headline-lg text-espresso">{p.name}</h3>
          <p class="font-body italic text-body-md text-cocoa">{p.flavor}</p>
          <span class="font-label text-label-caps uppercase tracking-widest text-copper opacity-0 group-hover:opacity-100 transition-opacity duration-500 pt-2">
            Discover →
          </span>
        </div>
      </a>
    ))}
  </div>

  <p class="text-center font-body italic text-body-md text-cocoa pt-8">
    Crafted by hand in small batches, every week.
  </p>
</section>
